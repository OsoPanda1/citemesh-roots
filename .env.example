# ============================================================================
# NOA-TAMV: Variables de Entorno
# ============================================================================
# Copiar este archivo a .env y configurar los valores reales
# NUNCA commitear el archivo .env real
# ============================================================================

# ----------------------------------------------------------------------------
# Base de Datos (PostgreSQL + Prisma)
# ----------------------------------------------------------------------------
DATABASE_URL="postgresql://usuario:password@localhost:5432/tamv_core?schema=public"
DIRECT_URL="postgresql://usuario:password@localhost:5432/tamv_core?schema=public"

# ----------------------------------------------------------------------------
# Supabase
# ----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# ----------------------------------------------------------------------------
# Autenticación y Seguridad
# ----------------------------------------------------------------------------
JWT_SECRET=tu-jwt-secret-super-seguro-minimo-256-bits
ENCRYPTION_KEY=clave-de-cifrado-para-datos-sensibles
TEE_ATTESTATION_KEY=clave-para-atestacion-tee

# ----------------------------------------------------------------------------
# Servicios Externos
# ----------------------------------------------------------------------------
# Sourcegraph
SOURCEGRAPH_URL=https://sourcegraph.tamv.mesh
SOURCEGRAPH_TOKEN=sgp_tu-token-aqui

# Grafana
GRAFANA_URL=https://grafana.tamv.mesh
GRAFANA_API_KEY=glsa_tu-api-key

# Jupyter Hub
JUPYTER_HUB_URL=https://jupyter.tamv.mesh
JUPYTER_API_TOKEN=tu-jupyter-token

# Terraform Cloud (opcional)
TF_CLOUD_TOKEN=tf-api-tu-token
TF_ORGANIZATION=tamv-organization

# ----------------------------------------------------------------------------
# Configuración de Nodo Civilizatorio
# ----------------------------------------------------------------------------
CIVILIZATION_NODE_ID=node-001
CIVILIZATION_REGION=latam-mx-hidalgo
TRUST_TIER=4
DOMAINS_ENABLED=id-nvida,utamv,economy,security

# ----------------------------------------------------------------------------
# Email y Notificaciones
# ----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASSWORD=tu-app-password

# ----------------------------------------------------------------------------
# Modo de Operación
# ----------------------------------------------------------------------------
NODE_ENV=development
DEBUG=true
LOG_LEVEL=info

# ----------------------------------------------------------------------------
# Feature Flags
# ----------------------------------------------------------------------------
ENABLE_AUTO_REMEDIATION=true
ENABLE_FEDERATION_SYNC=true
ENABLE_AI_ASSISTANCE=true
ENABLE_OBSERVABILITY=true
